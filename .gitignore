# Root level gitignore for NedAI monorepo

# Dependencies (all subprojects)
**/node_modules/
.pnp
.pnp.js

# Build outputs (all subprojects)
**/dist/
**/dist-ssr/
*.local

# Environment files (all subprojects)
**/.env
**/.env.local
**/.env.*.local
**/.env.production

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage/
*.lcov

# Vite timestamp files
*.timestamp-*.mjs

# Expo
.expo/

# React Native
*.ipa
*.apk
