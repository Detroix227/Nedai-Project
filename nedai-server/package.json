{
  "name": "nedai-server",
  "type": "module",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --hot src/server.ts",
    "dev:node": "node --watch src/server.ts",
    "build": "bunx prisma migrate resolve --rolled-back 20260508104247_add_user_learning_profiles 2>/dev/null || true && bunx prisma migrate deploy && tsc --noEmit",
    "postinstall": "prisma generate",
    "generate": "prisma generate",
    "studio": "prisma studio",
    "push": "prisma db push",
    "reset": "prisma migrate reset",
    "test": "bun test",
    "ingest:knowledge": "bun run src/scripts/ingest-knowledge-sources.ts",
    "prepare:knowledge": "bun run src/scripts/prepare-knowledge-sources.ts",
    "embed:knowledge": "bun run src/scripts/backfill-knowledge-embeddings.ts",
    "migrate:global-knowledge": "bun run src/scripts/migrate-global-knowledge.ts",
    "make-admin": "bun run src/scripts/make-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.1",
    "groq-sdk": "^1.1.2",
    "hono": "^4.12.11",
    "mammoth": "^1.12.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "uploadthing": "^7.7.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3"
  }
}
