{
  "name": "nedai-desktop",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development electron .",
    "start": "electron .",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "build:web": "npm --prefix web run build",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.nedai.desktop",
    "productName": "NedAI",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/node_modules/onnxruntime-node/**/*",
      "**/node_modules/@lancedb/**/*",
      "**/node_modules/sharp/**/*",
      "**/node_modules/@napi-rs/canvas/**/*"
    ],
    "directories": {
      "output": "dist-installers"
    },
    "files": [
      "main.js",
      "engine.js",
      "preload.js",
      "web/dist/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "web/dist/nedai-symbol-v3.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "NedAI"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^18.1.0",
    "fs-extra": "^11.3.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  }
}
